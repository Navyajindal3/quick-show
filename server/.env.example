# QuickShow Server — Environment Variables
# ==========================================
# Copy this file to .env and fill in all required values.
# NEVER commit the actual .env file to version control.
#
# For local development with MongoDB transactions, you MUST use either:
#   a) MongoDB Atlas connection string (recommended), OR
#   b) A local replica set (see README.md for setup instructions)
#
# Standalone MongoDB does NOT support transactions and will cause startup failure.
# To override for development only: ALLOW_STANDALONE_MONGO=true

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Must be a replica set or Atlas URI (required for transactions)
# Atlas example: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/quickshow
# Local replica set example: mongodb://localhost:27017/quickshow?replicaSet=rs0
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/quickshow

# ─── Redis ────────────────────────────────────────────────────────────────────
# Required for distributed seat locking
# Upstash example: rediss://default:<password>@<host>:<port>
# Local example: redis://localhost:6379
REDIS_URI=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# MUST be at least 32 characters. MUST be different from TICKET_JWT_SECRET.
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRE=7d

# Used to sign ticket QR codes (tamper-evident, not encrypted)
# MUST be different from JWT_SECRET. At least 32 characters.
TICKET_JWT_SECRET=change_this_to_a_different_long_random_secret_32_chars

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Exact URL of your frontend (no trailing slash)
CLIENT_URL=http://localhost:5173

# Optional: comma-separated additional trusted origins (staging, preview)
# ADDITIONAL_ORIGINS=https://staging.yourapp.com,https://preview.yourapp.com

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Resend Email API ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── TMDB (for automatic movie sync) ─────────────────────────────────────────
TMDB_API_KEY=your_tmdb_api_key

# ─── Seat & Booking Limits ────────────────────────────────────────────────────
MAX_SEATS_PER_BOOKING=8
SEAT_LOCK_TTL_SECONDS=600

# ─── Admin Seed (only needed when running seed.js) ────────────────────────────
# SEED_ADMIN_EMAIL=admin@yourdomain.com
# SEED_ADMIN_PASSWORD=ChangeThisToAStrongPassword123!

# ─── Development Overrides ────────────────────────────────────────────────────
# WARNING: Do NOT set these in production.

# Allow standalone MongoDB (no transactions) — for development only.
# Payment finalization will NOT be atomic when this is set.
# ALLOW_STANDALONE_MONGO=true

# Number of proxies between the internet and this server (for IP-based rate limiting)
# Set to 1 if behind a single load balancer, 2 if behind two, etc.
TRUST_PROXY=0
